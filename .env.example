# Telegram API Credentials
# Get these from https://my.telegram.org/apps
API_ID=12345
API_HASH=your_api_hash_here

# Session String
# You can generate this by running a separate script or use phone number login
# Leave empty to use phone number login
SESSION_STRING=

# Optional: Command Prefix (default is .)
CMD_PREFIX=.

# Optional: Todoist Integration (.todo command)
TODOIST_API_TOKEN=

# Optional: Spam limits
MAX_SPAM_COUNT=100
SPAM_DELAY=0.5

# Client Customization
CLIENT_NAME=NekoUB
APP_VERSION=NekoUB 1.0.0
WORKERS=8
PARSE_MODE=markdown


# Sticker set name format
#
# Placeholders: {user_id}, {first_name}, {index}
#
# STICKERSET_NAME_FORMAT  -> short_name (used in deep links / API)
#   default: "a{user_id}_vol{index}"
# STICKERSET_TITLE_FORMAT -> display title shown in Telegram
#   default: "{first_name}'s Pack Vol{index}"
#
# Leave empty (or "") to use defaults.
# Make sure to include {index} so the bot can number packs.
STICKERSET_NAME_FORMAT=""
STICKERSET_TITLE_FORMAT=""
